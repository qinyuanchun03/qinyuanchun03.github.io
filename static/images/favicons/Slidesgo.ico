                                        Русский
                                    </option>
                                                                    <option value="ja">
                                        日本語
                                    </option>
                                                                    <option value="pa">
                                        ਪੰਜਾਬੀ
                                    </option>
                                                                    <option value="mr">
                                        मराठी
                                    </option>
                                                                    <option value="te">
                                        తెలుగు
                                    </option>
                                                                    <option value="tr">
                                        Türkçe
                                    </option>
                                                                    <option value="ko">
                                        한국어
                                    </option>
                                                                    <option value="vi">
                                        Tiếng Việt
                                    </option>
                                                                    <option value="ta">
                                        தமிழ்
                                    </option>
                                                                    <option value="yo">
                                        Yorùbá
                                    </option>
                                                                    <option value="ur">
                                        اردو
                                    </option>
                                                                    <option value="jv">
                                        Basa Jawa
